{
  "manifest_version": 2,
  "name": "Veil Embed Guard",
  "version": "1.0.0",
  "description": "Removes player iframe sandboxing and disables popup APIs.",
  "browser_specific_settings": {
    "gecko": {
      "id": "veil-embed-guard@pstream.android"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["embed-guard.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
